    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://room-50.netlify.app/ginse/input-schema.json",
    "title": "ROOM/50 café modeling brief request",
    "description": "Select one public ROOM/50 plan and describe the accessible neighbourhood café experience to brief.",
